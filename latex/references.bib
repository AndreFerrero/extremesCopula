@article{beare2010,
  title = {Copulas and {{Temporal Dependence}}},
  author = {Beare, Brendan K.},
  date = {2010},
  journaltitle = {Econometrica},
  shortjournal = {Econometrica},
  volume = {78},
  number = {1},
  pages = {395--410},
  issn = {0012-9682},
  doi = {10.3982/ECTA8152},
  abstract = {An emerging literature in time series econometrics concerns the modeling of potentially nonlinear temporal dependence in stationary Markov chains using copula functions. We obtain sufficient conditions for a geometric rate of mixing in models of this kind. Geometric β-mixing is established under a rather strong sufficient condition that rules out asymmetry and tail dependence in the copula function. Geometric ρ-mixing is obtained under a weaker condition that permits both asymmetry and tail dependence. We verify one or both of these conditions for a range of parametric copula functions that are popular in applied work.},
  langid = {english}
}

@article{beare2012,
  title = {{{ARCHIMEDEAN COPULAS AND TEMPORAL DEPENDENCE}}},
  author = {Beare, Brendan K.},
  date = {2012-12},
  journaltitle = {Econometric Theory},
  shortjournal = {Econom. Theory},
  volume = {28},
  number = {6},
  pages = {1165--1185},
  issn = {0266-4666, 1469-4360},
  doi = {10.1017/S0266466612000126},
  abstract = {We study the dependence properties of stationary Markov chains generated by Archimedean copulas. Under some simple regularity conditions, we show that regular variation of the Archimedean generator at zero and one implies geometric ergodicity of the associated Markov chain. We verify our assumptions for a range of Archimedean copulas used in applications.},
  langid = {english}
}

