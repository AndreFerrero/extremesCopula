  author = {Davis, Richard A. and Drees, Holger and Segers, Johan and Warchoł, Michał},
  date = {2018-08-01},
  journaltitle = {Journal of Econometrics},
  shortjournal = {Journal of Econometrics},
  volume = {205},
  number = {2},
