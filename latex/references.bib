  keywords = {$\beta$-mixing,60F17,60G70,62G20,62M10,ARCH-process,dependent,extreme value index,Hill estimator,invariance principle,statistical tail functional,stochastic difference equation,tail empirical distribution function,tail empirical quantile function,time series}
